<?xml version="1.0" encoding="UTF-8"?>

<?import com.github.yoep.popcorn.ui.view.controls.Overlay?>
<?import com.github.yoep.popcorn.ui.view.controls.VirtualKeyboard?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<GridPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
          fx:controller="com.github.yoep.popcorn.ui.view.controllers.tv.components.TvSettingsServerComponent"
          styleClass="sub-section">
    <columnConstraints>
        <ColumnConstraints/>
        <ColumnConstraints/>
        <ColumnConstraints hgrow="ALWAYS"/>
    </columnConstraints>
    <rowConstraints>
        <RowConstraints/>
        <RowConstraints/>
        <RowConstraints/>
        <RowConstraints/>
        <RowConstraints/>
    </rowConstraints>

    <!-- User interface title -->
    <Label styleClass="subsection-title" text="%settings_servers"
           GridPane.valignment="TOP" GridPane.rowSpan="4" GridPane.columnIndex="0" GridPane.rowIndex="0"/>

    <!-- Movies Server -->
    <Label styleClass="subsection-label" text="%settings_servers_movies"
           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
    <Button fx:id="movieServersBtn" styleClass="long"
            GridPane.columnIndex="2" GridPane.rowIndex="0"/>

    <!-- Series Server -->
    <Label styleClass="subsection-label" text="%settings_servers_series"
           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    <Button fx:id="seriesServersBtn" styleClass="long"
            GridPane.columnIndex="2" GridPane.rowIndex="1"/>

    <!-- Info -->
    <Label text="%settings_servers_description" styleClass="text-secondary"
           GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="2" />

    <!-- Auto update servers -->
    <CheckBox fx:id="updateServersAutomatically" text="%settings_auto_update_api_servers"
              GridPane.columnSpan="2" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

    <!-- Separator -->
    <Separator
            GridPane.columnSpan="2" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

    <Overlay fx:id="movieServersOverlay" for="$movieServersBtn" attachTo="settings">
        <GridPane>
            <columnConstraints>
                <ColumnConstraints minWidth="100" percentWidth="10"/>
                <ColumnConstraints maxWidth="700"/>
                <ColumnConstraints minWidth="100" percentWidth="10"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints/>
                <RowConstraints/>
                <RowConstraints/>
                <RowConstraints/>
            </rowConstraints>

            <Label fx:id="movieServersTxt" text="%settings_subtitles_default" styleClass="virtual-keyboard-value"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            <VirtualKeyboard fx:id="movieServersInput" minWidth="0"
                             enableSpecialKeys="true" enableCloseKey="true" onClose="#onCloseInputOverlay"
                             GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        </GridPane>
    </Overlay>
    <Overlay fx:id="serieServersOverlay" for="$seriesServersBtn" attachTo="settings">
        <GridPane>
            <columnConstraints>
                <ColumnConstraints minWidth="100" percentWidth="10"/>
                <ColumnConstraints maxWidth="700"/>
                <ColumnConstraints minWidth="100" percentWidth="10"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints/>
                <RowConstraints/>
                <RowConstraints/>
                <RowConstraints/>
            </rowConstraints>

            <Label fx:id="serieServersTxt" text="%settings_subtitles_default" styleClass="virtual-keyboard-value"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            <VirtualKeyboard fx:id="serieServersInput" minWidth="0"
                             enableSpecialKeys="true" enableCloseKey="true" onClose="#onCloseInputOverlay"
                             GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        </GridPane>
    </Overlay>
</GridPane>
